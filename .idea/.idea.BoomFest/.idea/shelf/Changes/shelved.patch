+        return order is null ? null : Map(order);
+    }
+
+    public async Task<OrderReadDto> CreateAsync(OrderCreateDto dto, CancellationToken cancellationToken = default)
+    {
+        await EnsureOrderRulesAsync(dto.UserId, dto.StripeSessionId, dto.TotalPrice, null, cancellationToken);
+
+        var order = new Order
+        {
+            UserId = dto.UserId,
+            StripeSessionId = dto.StripeSessionId.Trim(),
+            TotalPrice = dto.TotalPrice,
+            Status = dto.Status,
+            User = null!
+        };
+
+        var created = await repository.CreateAsync(order, cancellationToken);
+        return Map(created);
+    }
+
+    public async Task<OrderReadDto?> UpdateAsync(Guid id, OrderUpdateDto dto, CancellationToken cancellationToken = default)
+    {
+        var order = await repository.GetByIdAsync(id, cancellationToken);
+        if (order is null)
+        {
+            return null;
+        }
+
+        await EnsureOrderRulesAsync(dto.UserId, dto.StripeSessionId, dto.TotalPrice, id, cancellationToken);
+
+        order.UserId = dto.UserId;
+        order.StripeSessionId = dto.StripeSessionId.Trim();
+        order.TotalPrice = dto.TotalPrice;
+        order.Status = dto.Status;
+        order.User = null!;
+
+        var updated = await repository.UpdateAsync(order, cancellationToken);
+        return Map(updated);
+    }
+
+    public Task<bool> DeleteAsync(Guid id, CancellationToken cancellationToken = default)
+        => repository.DeleteAsync(id, cancellationToken);
+
+    private async Task EnsureOrderRulesAsync(Guid userId, string stripeSessionId, decimal totalPrice, Guid? orderId, CancellationToken cancellationToken)
+    {
+        if (totalPrice < 0)
+        {
+            throw new BusinessRuleException("Order TotalPrice cannot be negative.");
+        }
+
+        if (!await userRepository.ExistsAsync(userId, cancellationToken))
+        {
+            throw new BusinessRuleException("User does not exist.");
+        }
+
+        if (await repository.StripeSessionExistsAsync(stripeSessionId.Trim(), orderId, cancellationToken))
+        {
+            throw new BusinessRuleException("StripeSessionId must be unique.");
+        }
+    }
+
+    private static OrderReadDto Map(Order order) => new()
+    {
+        Id = order.Id,
+        UserId = order.UserId,
