+public sealed class LineupRepository(ApplicationDbContext context) : CrudRepository<Lineup>(context), ILineupRepository
+{
+    public override async Task<List<Lineup>> GetAllAsync(CancellationToken cancellationToken = default)
+        => await Context.Lineups
+            .AsNoTracking()
+            .Include(lineup => lineup.Festival)
+            .Include(lineup => lineup.Artist)
+            .ToListAsync(cancellationToken);
