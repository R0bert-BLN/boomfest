+using BoomFest.Data;
+using BoomFest.Models;
+using Microsoft.EntityFrameworkCore;
+
+namespace BoomFest.Repositories;
+
+public interface IOrderRepository : ICrudRepository<Order>
+{
+    Task<bool> StripeSessionExistsAsync(string stripeSessionId, Guid? excludedOrderId = null, CancellationToken cancellationToken = default);
+}
+
+public sealed class OrderRepository(ApplicationDbContext context) : CrudRepository<Order>(context), IOrderRepository
+{
+    public override async Task<List<Order>> GetAllAsync(CancellationToken cancellationToken = default)
+        => await Context.Orders
+            .AsNoTracking()
+            .Include(order => order.User)
+            .Include(order => order.Tickets)
+            .ToListAsync(cancellationToken);
+
+    public override async Task<Order?> GetByIdAsync(Guid id, CancellationToken cancellationToken = default)
+        => await Context.Orders
+            .AsNoTracking()
+            .Include(order => order.User)
+            .Include(order => order.Tickets)
+            .FirstOrDefaultAsync(order => order.Id == id, cancellationToken);
+
+    public Task<bool> StripeSessionExistsAsync(string stripeSessionId, Guid? excludedOrderId = null, CancellationToken cancellationToken = default)
+        => Context.Orders.AnyAsync(order => order.StripeSessionId == stripeSessionId && (!excludedOrderId.HasValue || order.Id != excludedOrderId.Value), cancellationToken);
