+using BoomFest.Dtos.Api;
+using BoomFest.Models;
+using BoomFest.Repositories;
+using BoomFest.Services.Interfaces;
+
+namespace BoomFest.Services;
+
+public sealed class LineupService(
+    ILineupRepository repository,
+    IFestivalRepository festivalRepository,
+    IArtistRepository artistRepository) : ILineupService
+{
+    public async Task<List<LineupReadDto>> GetAllAsync(CancellationToken cancellationToken = default)
+        => (await repository.GetAllAsync(cancellationToken)).Select(Map).ToList();
+
+    public async Task<LineupReadDto?> GetByIdAsync(Guid id, CancellationToken cancellationToken = default)
+    {
+        var lineup = await repository.GetByIdAsync(id, cancellationToken);
+        return lineup is null ? null : Map(lineup);
+    }
+
+    public async Task<LineupReadDto> CreateAsync(LineupCreateDto dto, CancellationToken cancellationToken = default)
+    {
+        await EnsureRelationsAndDatesAsync(dto.FestivalId, dto.ArtistId, dto.StartDate, dto.EndDate, cancellationToken);
+
+        var lineup = new Lineup
+        {
+            FestivalId = dto.FestivalId,
+            ArtistId = dto.ArtistId,
+            Description = dto.Description,
+            StartDate = dto.StartDate,
+            EndDate = dto.EndDate,
+            Festival = null!,
+            Artist = null!
+        };
+
+        var created = await repository.CreateAsync(lineup, cancellationToken);
+        return Map(created);
+    }
+
+    public async Task<LineupReadDto?> UpdateAsync(Guid id, LineupUpdateDto dto, CancellationToken cancellationToken = default)
+    {
+        await EnsureRelationsAndDatesAsync(dto.FestivalId, dto.ArtistId, dto.StartDate, dto.EndDate, cancellationToken);
+
+        var lineup = await repository.GetByIdAsync(id, cancellationToken);
+        if (lineup is null)
+        {
+            return null;
+        }
+
+        lineup.FestivalId = dto.FestivalId;
+        lineup.ArtistId = dto.ArtistId;
+        lineup.Description = dto.Description;
+        lineup.StartDate = dto.StartDate;
+        lineup.EndDate = dto.EndDate;
+        lineup.Festival = null!;
+        lineup.Artist = null!;
+
+        var updated = await repository.UpdateAsync(lineup, cancellationToken);
+        return Map(updated);
+    }
+
+    public Task<bool> DeleteAsync(Guid id, CancellationToken cancellationToken = default)
+        => repository.DeleteAsync(id, cancellationToken);
+
+    private async Task EnsureRelationsAndDatesAsync(Guid festivalId, Guid artistId, DateTime startDate, DateTime endDate, CancellationToken cancellationToken)
+    {
+        if (endDate <= startDate)
+        {
+            throw new BusinessRuleException("Lineup EndDate must be after StartDate.");
+        }
+
+        if (!await festivalRepository.ExistsAsync(festivalId, cancellationToken))
+        {
+            throw new BusinessRuleException("Festival does not exist.");
+        }
+
+        if (!await artistRepository.ExistsAsync(artistId, cancellationToken))
+        {
+            throw new BusinessRuleException("Artist does not exist.");
+        }
+
+        var festival = await festivalRepository.GetByIdAsync(festivalId, cancellationToken);
+        if (festival is not null && (startDate < festival.StartDate || endDate > festival.EndDate))
+        {
+            throw new BusinessRuleException("Lineup dates must be inside the festival dates.");
+        }
+    }
+
+    private static LineupReadDto Map(Lineup lineup) => new()
+    {
+        Id = lineup.Id,
+        FestivalId = lineup.FestivalId,
+        ArtistId = lineup.ArtistId,
+        Description = lineup.Description,
+        StartDate = lineup.StartDate,
+        EndDate = lineup.EndDate,
+        CreatedAt = lineup.CreatedAt,
+        UpdatedAt = lineup.UpdatedAt
+    };
+}
