+using BoomFest.Dtos.Api;
+using BoomFest.Enums;
+using BoomFest.Models;
+using BoomFest.Repositories;
+using BoomFest.Services.Interfaces;
+
+namespace BoomFest.Services;
+
+public sealed class TicketService(
+    ITicketRepository repository,
+    ITicketCategoryRepository categoryRepository,
+    IOrderRepository orderRepository,
+    IUserRepository userRepository) : ITicketService
+{
+    public async Task<List<TicketReadDto>> GetAllAsync(CancellationToken cancellationToken = default)
+        => (await repository.GetAllAsync(cancellationToken)).Select(Map).ToList();
+
+    public async Task<TicketReadDto?> GetByIdAsync(Guid id, CancellationToken cancellationToken = default)
+    {
+        var ticket = await repository.GetByIdAsync(id, cancellationToken);
+        return ticket is null ? null : Map(ticket);
+    }
+
+    public async Task<TicketReadDto> CreateAsync(TicketCreateDto dto, CancellationToken cancellationToken = default)
+    {
+        await EnsureTicketRulesAsync(dto, cancellationToken);
+
+        var ticket = new Ticket
+        {
+            CategoryId = dto.CategoryId,
+            OrderId = dto.OrderId,
+            Status = dto.Status,
+            ScannedAt = dto.ScannedAt,
+            ScannedBy = dto.ScannedBy,
+            Category = null!,
+            Order = null!
+        };
+
+        var created = await repository.CreateAsync(ticket, cancellationToken);
+        return Map(created);
+    }
+
+    public async Task<TicketReadDto?> UpdateAsync(Guid id, TicketUpdateDto dto, CancellationToken cancellationToken = default)
+    {
+        var ticket = await repository.GetByIdAsync(id, cancellationToken);
+        if (ticket is null)
+        {
+            return null;
+        }
+
+        await EnsureTicketRulesAsync(dto, cancellationToken);
+
+        ticket.CategoryId = dto.CategoryId;
+        ticket.OrderId = dto.OrderId;
+        ticket.Status = dto.Status;
+        ticket.ScannedAt = dto.ScannedAt;
+        ticket.ScannedBy = dto.ScannedBy;
+        ticket.Category = null!;
+        ticket.Order = null!;
+
+        var updated = await repository.UpdateAsync(ticket, cancellationToken);
+        return Map(updated);
+    }
+
+    public Task<bool> DeleteAsync(Guid id, CancellationToken cancellationToken = default)
+        => repository.DeleteAsync(id, cancellationToken);
+
+    private async Task EnsureTicketRulesAsync(TicketCreateDto dto, CancellationToken cancellationToken)
+    {
+        if (!await categoryRepository.ExistsAsync(dto.CategoryId, cancellationToken))
+        {
+            throw new BusinessRuleException("Ticket category does not exist.");
+        }
+
+        if (!await orderRepository.ExistsAsync(dto.OrderId, cancellationToken))
+        {
+            throw new BusinessRuleException("Order does not exist.");
+        }
+
+        if (dto.Status == TicketStatus.Used)
+        {
+            if (!dto.ScannedBy.HasValue || !dto.ScannedAt.HasValue)
+            {
+                throw new BusinessRuleException("Used tickets must have ScannedBy and ScannedAt.");
+            }
+
+            if (!await userRepository.ExistsAsync(dto.ScannedBy.Value, cancellationToken))
+            {
+                throw new BusinessRuleException("Scanner user does not exist.");
+            }
+        }
+    }
+
+    private static TicketReadDto Map(Ticket ticket) => new()
+    {
+        Id = ticket.Id,
+        CategoryId = ticket.CategoryId,
+        OrderId = ticket.OrderId,
+        QrCode = ticket.QrCode,
+        Status = ticket.Status,
+        ScannedAt = ticket.ScannedAt,
+        ScannedBy = ticket.ScannedBy,
+        CreatedAt = ticket.CreatedAt,
+        UpdatedAt = ticket.UpdatedAt
+    };
+}
