+
+        var created = await repository.CreateAsync(category, cancellationToken);
+        return Map(created);
+    }
+
+    public async Task<TicketCategoryReadDto?> UpdateAsync(Guid id, TicketCategoryUpdateDto dto, CancellationToken cancellationToken = default)
+    {
+        var category = await repository.GetByIdAsync(id, cancellationToken);
+        if (category is null)
+        {
+            return null;
+        }
+
+        await EnsureCategoryRulesAsync(dto.FestivalId, dto.Price, dto.Stock, cancellationToken);
+
+        category.FestivalId = dto.FestivalId;
+        category.Name = dto.Name.Trim();
+        category.Description = dto.Description;
+        category.Price = dto.Price;
+        category.Stock = dto.Stock;
