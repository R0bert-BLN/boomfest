{
  "name": "boomfest",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "css:build": "npx @tailwindcss/cli -i ./wwwroot/css/input.css -o ./wwwroot/css/output.css --minify",
    "js:build": "npx esbuild ./wwwroot/js/main.js --bundle --minify --outfile=./wwwroot/js/output.js",
    "build": "npm run css:build && npm run js:build",
    "watch:css": "npx @tailwindcss/cli -i ./wwwroot/css/input.css -o ./wwwroot/css/output.css --watch",
    "watch:js": "npx esbuild ./wwwroot/js/input.js --bundle --outfile=./wwwroot/js/output.js --watch"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "alpinejs": "^3.15.9",
    "daisyui": "^5.5.19",
    "esbuild": "^0.27.4",
    "tailwindcss": "^4.2.2"
  }
}
