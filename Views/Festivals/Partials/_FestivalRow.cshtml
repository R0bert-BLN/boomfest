@using BoomFest.Enums
@model Festival
@{
    var (statusText, statusClasses) = Model.Status switch
    {
        FestivalStatus.Published => ("Published", "bg-emerald-50 text-emerald-700 border-emerald-200"),
        FestivalStatus.Draft => ("Hidden", "bg-slate-100 text-slate-600 border-slate-200"),
        FestivalStatus.SoldOut => ("Sold Out", "bg-amber-50 text-amber-700 border-amber-200"),
        FestivalStatus.Cancelled => ("Canceled", "bg-rose-50 text-rose-700 border-rose-200"),
        _ => (Model.Status.ToString(), "bg-slate-100 text-slate-600 border-slate-200")
    };
}
<tr class="hover:bg-slate-50 transition-colors cursor-pointer" data-href="@(Url.Action("Edit", "Festivals", new { id = Model.Id }) ?? "#")">
    <td class="px-6 py-4">
        <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-lg bg-slate-100 overflow-hidden shrink-0">
                <img src="@(Model.PictureUrl ?? "/img/placeholder.png")" alt="@Model.Title poster" class="w-full h-full object-cover">
            </div>
            <div>
                <div class="font-bold text-slate-900 text-base">@Model.Title</div>
                <div class="text-[10px] text-slate-400 uppercase font-bold">@Model.StartDate.ToString("dd MMM yyyy")</div>
            </div>
        </div>
    </td>
    <td class="px-6 py-4">
        <div class="text-slate-600 text-xs font-medium">@Model.City, @Model.Country</div>
    </td>
    <td class="px-6 py-4 text-center">
        <span class="inline-flex items-center rounded-full border px-3 py-1 text-[10px] font-bold uppercase tracking-wide @statusClasses">
            @statusText
        </span>
    </td>
    <td class="px-6 py-4" data-no-row-nav>
        <div class="flex justify-end mr-5">
            <form asp-action="Delete" asp-controller="Festivals" asp-route-id="@Model.Id" method="post" class="inline">
                <button type="submit" class="text-slate-400 hover:text-red-600 transition-colors cursor-pointer" title="Delete festival" aria-label="Delete festival" onclick="return confirm('Delete this festival?');">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6M9 7V4a1 1 0 011-1h4a1 1 0 011 1v3M4 7h16"></path></svg>
                </button>
            </form>
        </div>
    </td>
</tr>