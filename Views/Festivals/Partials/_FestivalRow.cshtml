@using BoomFest.Enums
@model Festival
<tr class="hover:bg-slate-50 transition-colors">
    <td class="px-6 py-4">
        <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-lg bg-slate-100 overflow-hidden shrink-0">
                <img src="@(Model.PictureUrl ?? "/img/placeholder.png")" class="w-full h-full object-cover">
            </div>
            <div>
                <div class="font-bold text-slate-900 text-base">@Model.Title</div>
                <div class="text-[10px] text-slate-400 uppercase font-bold">@Model.StartDate.ToString("dd MMM yyyy")</div>
            </div>
        </div>
    </td>
    <td class="px-6 py-4">
        <div class="text-slate-600 text-xs font-medium">@Model.City, @Model.Country</div>
    </td>
    <td class="px-6 py-4 text-center">
        <span class="badge @(Model.Status == FestivalStatus.Published ? "badge-success" : "badge-ghost") badge-outline text-[10px] font-bold uppercase py-2.5">
            @Model.Status
        </span>
    </td>
    <td class="px-6 py-4 text-center">
        <div class="flex justify-end mr-5">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="text-slate-400 hover:text-brand">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
            </a>
        </div>
    </td>
</tr>