@using BoomFest.Enums

@model BoomFest.Dtos.FestivalDetailsDto
@{
    ViewData["Title"] = $"Edit Event: {Model.Title}";
    Layout = "_AdminLayout";
}

<form asp-action="Edit" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data" class="space-y-6" id="festival-edit-form">
    <input asp-for="Id" type="hidden" />
    <input asp-for="ExistingPictureUrl" type="hidden" />

    <div asp-validation-summary="ModelOnly" class="text-sm text-red-600"></div>

    <div class="bg-white border border-slate-200 rounded-xl px-6 py-4 flex flex-col xl:flex-row xl:items-center xl:justify-between gap-4 shadow-sm">
        <h1 class="text-lg font-bold text-slate-800 flex items-center gap-2">
            <a asp-action="Index" class="text-slate-400 hover:text-brand transition-colors" title="Back to festivals">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
                </svg>
            </a>
            Edit Event: @Model.Title
        </h1>

        <div class="flex gap-3 items-center flex-wrap">
            <span class="text-[10px] text-slate-400 uppercase font-bold tracking-widest">Status:</span>
            <select asp-for="Status" class="bg-slate-100 border border-slate-300 text-slate-700 text-xs font-bold rounded-lg px-3 py-1.5 focus:outline-none focus:ring-1 focus:ring-slate-400 cursor-pointer">
                <option value="@((int)FestivalStatus.Published)">Published (Active)</option>
                <option value="@((int)FestivalStatus.Draft)">Draft (Hidden)</option>
                <option value="@((int)FestivalStatus.SoldOut)">Sold Out</option>
                <option value="@((int)FestivalStatus.Cancelled)">Canceled</option>
            </select>

            <div class="w-px h-6 bg-slate-200 mx-1"></div>

            <a asp-action="Index" class="px-4 py-2 text-sm font-medium text-slate-500 hover:text-slate-800 transition-colors">Cancel</a>
            <button type="submit" class="bg-brand text-white px-5 py-2 rounded-lg text-sm font-bold hover:bg-brand-hover shadow-sm transition-colors">
                Save Changes
            </button>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
        <div class="lg:col-span-8 space-y-6">
            <div class="bg-white p-6 rounded-xl border border-slate-200 shadow-sm">
                <h2 class="text-base font-bold text-slate-900 mb-5">General Information</h2>

                <div class="space-y-5">
                    <div>
                        <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-2">Event Poster Banner</label>
                        <label for="poster-upload" class="h-28 w-full border-2 border-dashed border-slate-300 rounded-lg flex flex-col items-center justify-center text-slate-500 bg-slate-50 hover:bg-slate-100 hover:border-brand transition-colors cursor-pointer group">
                            <svg class="w-6 h-6 mb-1 text-slate-400 group-hover:text-brand transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                            </svg>
                            <span id="poster-file-name" class="text-xs font-medium">Click to upload or drag image here (1200x800px)</span>
                        </label>
                        <input id="poster-upload" asp-for="PictureFile" type="file" class="hidden" accept="image/*" />
                        @if (!string.IsNullOrWhiteSpace(Model.ExistingPictureUrl))
                        {
                            <p class="text-[11px] text-slate-400 mt-2">Current poster configured.</p>
                        }
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                        <div>
                            <label asp-for="Title" class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-2">Event Title</label>
                            <input asp-for="Title" class="w-full px-3 py-2 bg-white border border-slate-300 rounded-md text-sm font-medium focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand transition-colors" />
                            <span asp-validation-for="Title" class="text-xs text-red-600"></span>
                        </div>
                        <div>
                            <label asp-for="Location" class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-2">Location / Venue</label>
                            <input asp-for="Location" class="w-full px-3 py-2 bg-white border border-slate-300 rounded-md text-sm font-medium focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand transition-colors" />
                            <span asp-validation-for="Location" class="text-xs text-red-600"></span>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                        <div>
                            <label asp-for="StartDate" class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-2">Start Date</label>
                            <input asp-for="StartDate" type="datetime-local" value="@Model.StartDate.ToString("yyyy-MM-ddTHH:mm")" class="w-full px-3 py-2 bg-white border border-slate-300 rounded-md text-sm font-medium focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand transition-colors" />
                            <span asp-validation-for="StartDate" class="text-xs text-red-600"></span>
                        </div>
                        <div>
                            <label asp-for="EndDate" class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-2">End Date</label>
                            <input asp-for="EndDate" type="datetime-local" value="@Model.EndDate.ToString("yyyy-MM-ddTHH:mm")" class="w-full px-3 py-2 bg-white border border-slate-300 rounded-md text-sm font-medium focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand transition-colors" />
                            <span asp-validation-for="EndDate" class="text-xs text-red-600"></span>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                        <div>
                            <label asp-for="City" class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-2">City</label>
                            <input asp-for="City" class="w-full px-3 py-2 bg-white border border-slate-300 rounded-md text-sm font-medium focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand transition-colors" />
                            <span asp-validation-for="City" class="text-xs text-red-600"></span>
                        </div>
                        <div>
                            <label asp-for="Country" class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-2">Country</label>
                            <input asp-for="Country" class="w-full px-3 py-2 bg-white border border-slate-300 rounded-md text-sm font-medium focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand transition-colors" />
                            <span asp-validation-for="Country" class="text-xs text-red-600"></span>
                        </div>
                    </div>

                    <div>
                        <label asp-for="Description" class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-2">Description (Public)</label>
                        <textarea asp-for="Description" rows="4" maxlength="500" class="w-full px-3 py-2 bg-white border border-slate-300 rounded-md text-sm focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand transition-colors resize-none"></textarea>
                        <span asp-validation-for="Description" class="text-xs text-red-600"></span>
                    </div>
                </div>
            </div>

            <div class="bg-white p-6 rounded-xl border border-slate-200 shadow-sm">
                <h2 class="text-base font-bold text-slate-900 mb-5">Line-up & Artists</h2>
                <div id="lineup-container" class="space-y-3">
                    @for (var i = 0; i < Model.Lineups.Count; i++)
                    {
                        <div class="flex items-center gap-4 p-3 border border-slate-200 rounded-lg bg-white hover:border-brand transition-colors" data-lineup-row>
                            <input type="hidden" name="Lineups.Index" value="@i" />
                            <input asp-for="Lineups[i].Id" type="hidden" />
                            <input asp-for="Lineups[i].IsDeleted" type="hidden" class="lineup-deleted-input" />

                            @if (!string.IsNullOrWhiteSpace(Model.Lineups[i].PictureUrl))
                            {
                                <img src="@Model.Lineups[i].PictureUrl" class="w-10 h-10 rounded shadow-sm object-cover" alt="Artist" />
                            }
                            else
                            {
                                <div class="w-10 h-10 rounded bg-slate-100 text-slate-500 text-xs font-bold flex items-center justify-center">ART</div>
                            }

                            <div class="flex-1 flex gap-3">
                                <div class="w-1/2">
                                    <input asp-for="Lineups[i].ArtistName" class="w-full px-2 py-1 bg-transparent border-b border-transparent focus:border-slate-300 focus:outline-none text-sm font-bold text-slate-800" placeholder="Artist name" />
                                    <span asp-validation-for="Lineups[i].ArtistName" class="text-xs text-red-600"></span>
                                </div>
                                <div class="w-1/2">
                                    <input asp-for="Lineups[i].SlotDetails" class="w-full px-2 py-1 bg-transparent border-b border-transparent focus:border-slate-300 focus:outline-none text-xs text-slate-500 font-medium" placeholder="Stage & Time..." />
                                </div>
                            </div>

                            <button type="button" class="text-slate-300 hover:text-brand p-1 transition-colors remove-lineup-btn" title="Remove Artist">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                                </svg>
                            </button>
                        </div>
                    }
                </div>

                <button id="add-lineup-row" type="button" class="w-full mt-3 py-3 border-2 border-dashed border-slate-200 rounded-lg text-sm font-bold text-slate-500 hover:text-brand hover:border-brand hover:bg-rose-50 transition-all flex justify-center items-center gap-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                    </svg>
                    Add New Artist
                </button>
            </div>
        </div>

        <div class="lg:col-span-4 space-y-6">

            <div class="bg-white p-6 rounded-xl border border-slate-200 shadow-sm">
                <div class="flex justify-between items-center mb-5">
                    <h2 class="text-base font-bold text-slate-900">Ticket Inventory</h2>
                    <span class="text-[10px] font-bold bg-slate-100 text-slate-500 px-2 py-1 rounded">@Model.TicketCategories.Count(t => !t.IsDeleted) Tiers</span>
                </div>

                <div id="ticket-container" class="space-y-3">
                    @for (var i = 0; i < Model.TicketCategories.Count; i++)
                    {
                        <div class="p-3 bg-white border border-slate-200 rounded-lg hover:border-slate-300 transition-colors shadow-sm" data-ticket-row>
                            <input type="hidden" name="TicketCategories.Index" value="@i" />
                            <input asp-for="TicketCategories[i].Id" type="hidden" />
                            <input asp-for="TicketCategories[i].IsDeleted" type="hidden" class="ticket-deleted-input" />

                            <div class="flex justify-between items-start mb-3 gap-3">
                                <div class="flex-1">
                                    <input asp-for="TicketCategories[i].Name" class="font-bold text-sm text-slate-900 w-full outline-none focus:border-b focus:border-brand bg-transparent p-0" placeholder="Tier name" />
                                    <input asp-for="TicketCategories[i].Description" class="text-[10px] text-slate-400 uppercase font-bold w-full outline-none mt-0.5 bg-transparent p-0" placeholder="Short description" />
                                    <span asp-validation-for="TicketCategories[i].Name" class="text-xs text-red-600"></span>
                                </div>
                                <div class="flex items-center">
                                    <input asp-for="TicketCategories[i].Price" type="number" step="0.01" class="font-black text-brand text-right w-16 outline-none bg-transparent" />
                                    <span class="text-xs font-bold text-brand ml-1">RON</span>
                                </div>
                            </div>

                            <div class="flex justify-between items-center bg-slate-50 p-2 rounded border border-slate-100 gap-3">
                                <span class="text-xs font-bold text-slate-500">Max Capacity:</span>
                                <div class="flex items-center gap-2">
                                    <input asp-for="TicketCategories[i].Stock" type="number" class="w-20 p-1 border border-slate-200 rounded text-right text-xs font-bold focus:outline-none focus:border-brand" />
                                    <button type="button" class="text-slate-300 hover:text-brand transition-colors remove-ticket-btn" title="Remove tier">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6M4 7h16"></path>
                                        </svg>
                                    </button>
                                </div>
                            </div>
                            <span asp-validation-for="TicketCategories[i].Price" class="text-xs text-red-600"></span>
                            <span asp-validation-for="TicketCategories[i].Stock" class="text-xs text-red-600 ml-2"></span>
                        </div>
                    }
                </div>

                <span asp-validation-for="TicketCategories" class="text-xs text-red-600"></span>

                <button id="add-ticket-row" type="button" class="w-full mt-4 py-2 border-2 border-dashed border-slate-200 text-slate-500 font-bold rounded-lg text-xs hover:text-brand hover:border-brand hover:bg-rose-50 transition-all">
                    + Add Ticket Tier
                </button>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <script>
        (function () {
            var lineupIndex = @Model.Lineups.Count;
            var ticketIndex = @Model.TicketCategories.Count;
            var lineupContainer = document.getElementById("lineup-container");
            var ticketContainer = document.getElementById("ticket-container");

            var lineupTemplate =
                '<div class="flex items-center gap-4 p-3 border border-slate-200 rounded-lg bg-white hover:border-brand transition-colors" data-lineup-row>' +
                '<input type="hidden" name="Lineups.Index" value="__index__" />' +
                '<input type="hidden" name="Lineups[__index__].Id" value="" />' +
                '<input type="hidden" name="Lineups[__index__].IsDeleted" value="false" class="lineup-deleted-input" />' +
                '<div class="w-10 h-10 rounded bg-slate-100 text-slate-500 text-xs font-bold flex items-center justify-center">ART</div>' +
                '<div class="flex-1 flex gap-3">' +
                '<div class="w-1/2"><input name="Lineups[__index__].ArtistName" class="w-full px-2 py-1 bg-transparent border-b border-transparent focus:border-slate-300 focus:outline-none text-sm font-bold text-slate-800" placeholder="Artist name" /></div>' +
                '<div class="w-1/2"><input name="Lineups[__index__].SlotDetails" class="w-full px-2 py-1 bg-transparent border-b border-transparent focus:border-slate-300 focus:outline-none text-xs text-slate-500 font-medium" placeholder="Stage & Time..." /></div>' +
                '</div>' +
                '<button type="button" class="text-slate-300 hover:text-brand p-1 transition-colors remove-lineup-btn" title="Remove Artist">' +
                '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>' +
                '</button></div>';

            var ticketTemplate =
                '<div class="p-3 bg-white border border-slate-200 rounded-lg hover:border-slate-300 transition-colors shadow-sm" data-ticket-row>' +
                '<input type="hidden" name="TicketCategories.Index" value="__index__" />' +
                '<input type="hidden" name="TicketCategories[__index__].Id" value="" />' +
                '<input type="hidden" name="TicketCategories[__index__].IsDeleted" value="false" class="ticket-deleted-input" />' +
                '<div class="flex justify-between items-start mb-3 gap-3"><div class="flex-1">' +
                '<input name="TicketCategories[__index__].Name" class="font-bold text-sm text-slate-900 w-full outline-none focus:border-b focus:border-brand bg-transparent p-0" placeholder="Tier name" />' +
                '<input name="TicketCategories[__index__].Description" class="text-[10px] text-slate-400 uppercase font-bold w-full outline-none mt-0.5 bg-transparent p-0" placeholder="Short description" />' +
                '</div><div class="flex items-center">' +
                '<input type="number" name="TicketCategories[__index__].Price" step="0.01" value="0" class="font-black text-brand text-right w-16 outline-none bg-transparent" />' +
                '<span class="text-xs font-bold text-brand ml-1">RON</span></div></div>' +
                '<div class="flex justify-between items-center bg-slate-50 p-2 rounded border border-slate-100 gap-3">' +
                '<span class="text-xs font-bold text-slate-500">Max Capacity:</span><div class="flex items-center gap-2">' +
                '<input name="TicketCategories[__index__].Stock" type="number" value="0" class="w-20 p-1 border border-slate-200 rounded text-right text-xs font-bold focus:outline-none focus:border-brand" />' +
                '<button type="button" class="text-slate-300 hover:text-brand transition-colors remove-ticket-btn" title="Remove tier">' +
                '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6M4 7h16"></path></svg>' +
                '</button></div></div></div>';

            function hideAndFlagRow(button, rowSelector, deletedSelector) {
                var row = button.closest(rowSelector);
                if (!row) {
                    return;
                }

                var deletedInput = row.querySelector(deletedSelector);
                if (deletedInput) {
                    deletedInput.value = "true";
                }

                row.classList.add("hidden");
            }

            var posterUpload = document.getElementById("poster-upload");
            var posterFileName = document.getElementById("poster-file-name");
            if (posterUpload && posterFileName) {
                posterUpload.addEventListener("change", function () {
                    if (posterUpload.files && posterUpload.files.length > 0) {
                        posterFileName.textContent = posterUpload.files[0].name;
                    }
                });
            }

            document.getElementById("add-lineup-row").addEventListener("click", function () {
                lineupContainer.insertAdjacentHTML("beforeend", lineupTemplate.replaceAll("__index__", lineupIndex));
                lineupIndex += 1;
            });

            document.getElementById("add-ticket-row").addEventListener("click", function () {
                ticketContainer.insertAdjacentHTML("beforeend", ticketTemplate.replaceAll("__index__", ticketIndex));
                ticketIndex += 1;
            });

            lineupContainer.addEventListener("click", function (event) {
                var button = event.target.closest(".remove-lineup-btn");
                if (!button) {
                    return;
                }

                hideAndFlagRow(button, "[data-lineup-row]", ".lineup-deleted-input");
            });

            ticketContainer.addEventListener("click", function (event) {
                var button = event.target.closest(".remove-ticket-btn");
                if (!button) {
                    return;
                }

                hideAndFlagRow(button, "[data-ticket-row]", ".ticket-deleted-input");
            });
        })();
    </script>
}
