@model IEnumerable<User>
@{
    ViewData["Title"] = "Users Management";
    Layout = "_AdminLayout";
    var query = ViewData["SearchQuery"]?.ToString() ?? string.Empty;
}

<div class="max-w-7xl mx-auto">
    <!-- Header with Search and Action Button -->
    <div class="flex flex-col md:flex-row justify-between items-center mb-6 gap-4">
        
        <!-- Search Form -->
        <form method="get" class="w-full md:w-auto">
            <input type="text" name="q" value="@query" placeholder="Search..." class="px-4 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:border-brand w-full md:w-72 shadow-sm">
        </form>

        <!-- Add User Button -->
        <a asp-action="Create" class="bg-brand hover:bg-brand-hover text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors shadow-sm flex items-center gap-2 whitespace-nowrap">
            <svg class="w-5 h-5" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
            Add User
        </a>
    </div>

    <!-- Users Table -->
    <div class="bg-white border border-slate-200 shadow-sm rounded-xl overflow-hidden">
        <table class="table w-full text-left border-collapse">
            <thead>
                <tr class="bg-slate-50 text-[10px] text-slate-500 uppercase tracking-widest border-b border-slate-200">
                    <th class="px-8 py-5 font-bold">User</th>
                    <th class="px-6 py-5 font-bold">Contact</th>
                    <th class="px-6 py-5 font-bold">Role</th>
                    <th class="px-6 py-5 font-bold">Registration Date</th>
                    <th class="px-8 py-5 text-right font-bold">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="5" class="px-8 py-8 text-sm text-slate-400 text-center">No users found.</td>
                </tr>
            }
            else
            {
                @foreach (var user in Model)
                {
                    var initials = string.Concat(user.FirstName.FirstOrDefault(), user.LastName.FirstOrDefault()).ToUpperInvariant();
                    var editUrl = Url.Action("Edit", new { id = user.Id }) ?? "#";

                    <tr class="hover:bg-slate-50 transition-colors cursor-pointer" data-href="@editUrl">
                        <td class="px-8 py-5">
                            <div class="flex items-center gap-4">
                                <div class="w-10 h-10 rounded-full @(user.Role == BoomFest.Enums.UserRole.Staff ? "bg-purple-100 text-purple-600" : "bg-blue-100 text-blue-600") flex items-center justify-center font-semibold text-sm shrink-0">
                                    @initials
                                </div>
                                <span class="font-medium text-[15px] text-slate-900">@user.FirstName @user.LastName</span>
                            </div>
                        </td>
                        <td class="px-6 py-5 text-slate-600 text-sm">@user.Email</td>
                        <td class="px-6 py-5">
                            @if (user.Role == BoomFest.Enums.UserRole.Admin)
                            {
                                <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-slate-100 text-slate-700">@user.Role</span>
                            }
                            else if (user.Role == BoomFest.Enums.UserRole.Staff)
                            {
                                <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-purple-100 text-purple-700">@user.Role</span>
                            }
                            else
                            {
                                <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-blue-100 text-blue-700">@user.Role</span>
                            }
                        </td>
                        <td class="px-6 py-5 text-slate-500 text-sm">@user.CreatedAt.ToLocalTime().ToString("dd MMM yyyy")</td>
                        
                        <!-- Delete Action (Kept as requested) -->
                        <td class="px-8 py-5" data-no-row-nav>
                            <div class="flex justify-end items-center">
                                <form asp-action="Delete" asp-route-id="@user.Id" method="post" class="inline">
                                    <button type="submit" class="p-1.5 text-slate-300 hover:text-red-600 transition-colors cursor-pointer" title="Delete user" aria-label="Delete user" onclick="return confirm('Are you sure you want to delete this user?');">
                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6M9 7V4a1 1 0 011-1h4a1 1 0 011 1v3M4 7h16"></path></svg>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        document.querySelectorAll("tr[data-href]").forEach(function (row) {
            row.addEventListener("click", function (event) {
                // Ignore click if it happened inside the actions cell
                if (event.target.closest("[data-no-row-nav]")) {
                    return;
                }

                const href = row.getAttribute("data-href");
                if (href) {
                    window.location.href = href;
                }
            });
        });
    </script>
}