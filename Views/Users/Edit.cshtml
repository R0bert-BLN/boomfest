@using BoomFest.Enums
@model BoomFest.Dtos.UserDto
@{
    ViewData["Title"] = "Edit User";
    Layout = "_AdminLayout";
}

<div class="max-w-4xl mx-auto pb-8">
    <div class="flex items-center gap-4 mb-10">
        <a asp-action="Index" class="group flex items-center justify-center w-8 h-8 rounded-full border border-slate-200 bg-white hover:border-brand transition-all shadow-sm">
            <svg class="w-4 h-4 text-slate-500 group-hover:text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
        </a>
        <h2 class="text-lg font-bold text-slate-800">Edit User</h2>
    </div>

    <form asp-action="Edit" asp-route-id="@Model.Id" method="post" class="space-y-8">
        <input asp-for="Id" type="hidden" />

        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
            <div class="p-8 space-y-6">
                <div asp-validation-summary="ModelOnly" class="text-sm text-red-600"></div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label asp-for="FirstName" class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-2">First Name</label>
                        <input asp-for="FirstName" class="w-full px-4 py-2.5 bg-white border border-slate-300 rounded-lg text-sm font-medium focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand transition-all" />
                        <span asp-validation-for="FirstName" class="text-xs text-red-600"></span>
                    </div>
                    <div>
                        <label asp-for="LastName" class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-2">Last Name</label>
                        <input asp-for="LastName" class="w-full px-4 py-2.5 bg-white border border-slate-300 rounded-lg text-sm font-medium focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand transition-all" />
                        <span asp-validation-for="LastName" class="text-xs text-red-600"></span>
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label asp-for="Email" class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-2">Email</label>
                        <input asp-for="Email" class="w-full px-4 py-2.5 bg-white border border-slate-300 rounded-lg text-sm font-medium focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand transition-all" />
                        <span asp-validation-for="Email" class="text-xs text-red-600"></span>
                    </div>
                    <div>
                        <label asp-for="Role" class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-2">Role</label>
                        <div class="relative">
                            <select asp-for="Role" asp-items="Html.GetEnumSelectList<UserRole>()" class="select w-full px-4 py-2.5 bg-white border border-slate-300 rounded-lg text-sm font-bold text-slate-700 focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand appearance-none transition-all cursor-pointer"></select>
                            <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-3 text-slate-400">
                                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                            </div>
                        </div>
                        <span asp-validation-for="Role" class="text-xs text-red-600"></span>
                    </div>
                </div>

                <div>
                    <label asp-for="Password" class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-2">New Password (optional)</label>
                    <input asp-for="Password" type="password" class="w-full px-4 py-2.5 bg-white border border-slate-300 rounded-lg text-sm font-medium focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand transition-all" placeholder="Leave blank to keep current password" />
                    <span asp-validation-for="Password" class="text-xs text-red-600"></span>
                </div>
            </div>

            <div class="px-8 pb-5 flex justify-end">
                <button type="submit" class="bg-brand cursor-pointer hover:bg-brand-hover text-white px-10 py-2.5 rounded-lg text-xs font-black uppercase tracking-widest shadow-md shadow-brand/20 transition-all transform active:scale-95">
                    Update User
                </button>
            </div>
        </div>
    </form>
</div>



