@using System.Globalization
@model BoomFest.Dtos.LandingPageDto

<header class="relative bg-dark pt-12 pb-28 flex items-center justify-center text-center">
    <div class="absolute inset-0">
        <div class="absolute inset-0 bg-gradient-to-t from-dark to-transparent"></div>
    </div>

    <div class="relative container mx-auto px-6 flex flex-col items-center">
        <h1 class="text-4xl md:text-5xl font-bold text-white mb-4 leading-tight">
            Find your <span class="text-transparent bg-clip-text bg-gradient-to-r from-brand to-rose-400">rhythm.</span>
        </h1>
        <p class="text-base text-slate-300 mb-8 max-w-xl">Buy official tickets securely and quickly for the biggest festivals and concerts in Romania.</p>
    </div>
</header>

<main class="flex-1 container mx-auto px-6 py-12 w-[1200px]">
    <div class="flex justify-between items-end mb-8">
        <div>
            <h2 class="text-2xl font-bold text-slate-900">Recommended Events</h2>
            <p class="text-sm text-slate-500 mt-1">The most popular festivals of the summer.</p>
        </div>

        <a asp-controller="Events" asp-action="Index" class="flex items-center text-brand text-sm font-semibold hover:text-brand-hover transition-colors">
            View all
            <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
        </a>
    </div>

    <div class="grid grid-cols-3 gap-6">
        @if (Model.Festivals.Count == 0)
        {
            <div class="col-span-3 bg-white rounded-xl shadow-sm border border-slate-200 p-6 text-center text-sm text-slate-500">
                No festivals available yet.
            </div>
        }
        else
        {
            @foreach (var festival in Model.Festivals)
            {
                var fallbackImage = "https://images.unsplash.com/photo-1459749411175-04bf5292ceea?q=80&w=600&auto=format&fit=crop";
                var day = festival.StartDate.ToString("dd", CultureInfo.InvariantCulture);
                var month = festival.StartDate.ToString("MMM", CultureInfo.InvariantCulture);
                var priceText = festival.MinPrice.HasValue
                    ? $"{festival.MinPrice.Value:0} RON"
                    : "TBA";

                <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden group hover:shadow-md transition-all flex flex-col">
                    <div class="relative h-40 overflow-hidden">
                        <img src="@(festival.PictureUrl ?? fallbackImage)" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" alt="@festival.Title">
                        <div class="absolute top-2 left-2 bg-white text-slate-900 text-[10px] font-bold px-2 py-1 rounded shadow-sm"><span class="text-brand">@day</span> @month</div>
                    </div>

                    <div class="p-4 flex-1 flex flex-col">
                        <h3 class="text-base font-bold text-slate-900 mb-1 group-hover:text-brand transition-colors">@festival.Title</h3>
                        <p class="text-xs text-slate-500 mb-3 flex items-center">
                            <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                            </svg>
                            @festival.Location
                        </p>

                        <div class="mt-auto pt-3 border-t border-slate-100 flex items-center justify-between">
                            <span class="text-sm font-bold text-slate-900">@priceText</span>
                            <a asp-controller="Events" asp-action="Details" asp-route-id="@festival.Id" class="bg-brand hover:bg-brand-hover text-white px-3.5 py-1 rounded-md text-[13px] font-bold transition-colors shadow-sm">Buy</a>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</main>
