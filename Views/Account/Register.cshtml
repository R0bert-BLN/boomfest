@model BoomFest.Dtos.RegisterDto
@{
    ViewData["Title"] = "Sign up";
}

<main class="flex-1 container mx-auto px-6 py-16 flex items-center justify-center">
    <div class="w-full max-w-md bg-white border border-slate-200 rounded-2xl shadow-sm p-8">
        <h1 class="text-2xl font-bold text-slate-900 mb-2">Create your account</h1>
        <p class="text-sm text-slate-500 mb-6">Join ShowTime to access tickets and exclusive drops.</p>

        <form asp-action="Register" method="post" class="space-y-4">
            <div asp-validation-summary="ModelOnly" class="text-sm text-red-600"></div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    <label asp-for="FirstName" class="block text-[11px] font-bold text-slate-400 uppercase tracking-widest mb-2"></label>
                    <input asp-for="FirstName" class="w-full px-3 py-2 bg-white border border-slate-300 rounded-md text-sm focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand transition-colors" />
                    <span asp-validation-for="FirstName" class="text-xs text-red-600"></span>
                </div>
                <div>
                    <label asp-for="LastName" class="block text-[11px] font-bold text-slate-400 uppercase tracking-widest mb-2"></label>
                    <input asp-for="LastName" class="w-full px-3 py-2 bg-white border border-slate-300 rounded-md text-sm focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand transition-colors" />
                    <span asp-validation-for="LastName" class="text-xs text-red-600"></span>
                </div>
            </div>

            <div>
                <label asp-for="Email" class="block text-[11px] font-bold text-slate-400 uppercase tracking-widest mb-2"></label>
                <input asp-for="Email" class="w-full px-3 py-2 bg-white border border-slate-300 rounded-md text-sm focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand transition-colors" />
                <span asp-validation-for="Email" class="text-xs text-red-600"></span>
            </div>

            <div>
                <label asp-for="Password" class="block text-[11px] font-bold text-slate-400 uppercase tracking-widest mb-2"></label>
                <input asp-for="Password" class="w-full px-3 py-2 bg-white border border-slate-300 rounded-md text-sm focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand transition-colors" />
                <span asp-validation-for="Password" class="text-xs text-red-600"></span>
            </div>

            <button type="submit" class="w-full bg-brand hover:bg-brand-hover text-white px-4 py-2 rounded-lg text-sm font-semibold transition-colors shadow-sm">Create account</button>
        </form>

        <p class="text-sm text-slate-500 mt-6 text-center">
            Already have an account?
            <a asp-action="Login" class="text-brand font-semibold hover:text-brand-hover">Log in</a>
        </p>
    </div>
</main>

