<!DOCTYPE html>

<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ShowTime</title>
    <link rel="stylesheet" href="~/css/output.css" asp-append-version="true" />
    <script src="~/js/output.js" asp-append-version="true" defer></script>
</head>
<body class="bg-slate-50 text-slate-800 font-sans min-h-screen flex flex-col">
<nav class="bg-dark border-b border-slate-200 py-4 shadow-sm">
    <div class="container mx-auto px-6 flex justify-center items-center">
        <a asp-controller="Home" asp-action="Index" class="flex items-center gap-2 text-xl font-bold tracking-wide text-slate-200 hover:text-brand transition-colors">
            <svg class="w-6 h-6 text-brand" fill="currentColor" viewBox="0 0 20 20"><path d="M2 6a2 2 0 012-2h12a2 2 0 012 2v2a2 2 0 100 4v2a2 2 0 01-2 2H4a2 2 0 01-2-2v-2a2 2 0 100-4V6z" /></svg>
            ShowTime <span class="text-slate-300 font-light mx-2">|</span> <span class="text-sm text-slate-200 font-medium">Secure Checkout</span>
        </a>
    </div>
</nav>

@RenderBody()

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>

