@{
    var currentController = ViewContext.RouteData.Values["Controller"]?.ToString();
}

<aside class="w-64 bg-sidebar text-slate-300 flex flex-col shadow-2xl z-20 shrink-0">
    <div class="h-16 flex items-center px-6 border-b border-slate-800">
        <svg class="w-8 h-8 text-brand mr-2" fill="currentColor" viewBox="0 0 20 20"><path d="M2 6a2 2 0 012-2h12a2 2 0 012 2v2a2 2 0 100 4v2a2 2 0 01-2 2H4a2 2 0 01-2-2v-2a2 2 0 100-4V6z" /></svg>
        <span class="text-white text-xl font-bold tracking-wide">BoomFest</span>
    </div>

    <nav class="flex-1 px-4 py-6 space-y-2 overflow-y-auto">
        <a asp-controller="Admin" asp-action="Dashboard" 
           class="flex items-center gap-3 px-3 py-2 rounded-lg transition-colors @(currentController == "Admin" ? "bg-brand text-white shadow-md shadow-brand/20" : "hover:bg-slate-800 hover:text-white")">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"></path></svg>
            <span class="font-medium">Dashboard</span>
        </a>

        <a asp-controller="Festivals" asp-action="Index" 
           class="flex items-center gap-3 px-3 py-2 rounded-lg transition-colors @(currentController == "Festivals" ? "bg-brand text-white shadow-md shadow-brand/20" : "hover:bg-slate-800 hover:text-white")">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
            <span class="font-medium">Festivals</span>
        </a>
    </nav>

    <div class="p-3 border-t border-slate-800">
        <a href="#" class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-slate-800 hover:text-white transition-colors">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path></svg>
            <span class="font-medium">Logout</span>
        </a>
    </div>
</aside>
